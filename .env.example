# sc-curation-pipeline — 环境变量模板
#
# 用法:  cp .env.example .env   然后填上你的真实值。
# dg dev / dg check defs 启动时会自动加载项目根目录的 .env(无需手动 export)。
# .env 已被 .gitignore 忽略、不会提交;本模板 .env.example 可以提交。

# 必填:要监控的根目录(放在 $SCRATCH 下)。缺失会直接报错。
SC_CURATION_WATCH_DIR=/scratch/users/chensj16/sc-curation-watch

# 必填:标准化输出 .h5ad 的根目录(绝不写入源目录)。缺失会直接报错。
SC_CURATION_OUTPUT_DIR=/scratch/users/chensj16/sc-curation-output

# 以下均为可选;留空/删除用默认值,写成非法值也会安全退回默认值。

# 上传完成标记文件名(默认 .done)
SC_CURATION_DONE_MARKER=.done

# 文件夹内匹配 h5ad 的模式(默认 *.h5ad)
SC_CURATION_H5AD_GLOB=*.h5ad

# sensor 最小扫描间隔,秒(默认 30)
SC_CURATION_SCAN_INTERVAL_SEC=30

# 细胞数下限,低于则拒收(默认 100)
SC_CURATION_MIN_CELLS=100

# 检测到的基因总数下限(在 ≥1 细胞中 counts>0 的基因数);低于则拒收(默认 5000)
SC_CURATION_MIN_GENES=5000

# 细胞级过滤(cell_filtered 步骤):每个细胞检出基因数 < 此值的细胞被剔除(默认 400)
SC_CURATION_MIN_GENES_PER_CELL=400

# 元数据列识别(stanmetacols):1=LLM 优先+启发式回退,0=离线启发式(确定性、零外部调用)。默认 1。
# ⚠️ Sherlock 计算节点跑批建议设 0:出网被代理黑洞时 LLM 读超时可能拖数十分钟才回退。
SC_CURATION_METACOLS_USE_LLM=1
# LLM 后端:provider=anthropic(默认,读 ANTHROPIC_API_KEY)或 openai(任意 OpenAI 兼容端点)。
# 用火山 ARK / 豆包的例子(key 不写这里,只填持有 key 的环境变量名):
#   SC_CURATION_METACOLS_PROVIDER=openai
#   SC_CURATION_METACOLS_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
#   SC_CURATION_METACOLS_MODEL=doubao-seed-2-0-pro-260215
#   SC_CURATION_METACOLS_API_KEY_ENV=ARK_API_KEY
SC_CURATION_METACOLS_PROVIDER=anthropic
SC_CURATION_METACOLS_MODEL=claude-opus-4-8
SC_CURATION_METACOLS_BASE_URL=
SC_CURATION_METACOLS_API_KEY_ENV=

# MrVI + Leiden 聚类(mrvi_leiden_h5ad):经 Dagster Pipes 用 sbatch 提交 Slurm GPU 作业训练。
# ⚠️ 必须用支持 batch 作业的 GPU 分区(gpu)。dev 只收交互式(salloc/srun/OnDemand),
# sbatch 提到 dev 会被直接拒("Batch jobs are not allowed in the 'dev' partition")。
# -G 1 由 client 固定;短 time 更易被 backfill 提前调度。
SC_CURATION_MRVI_PARTITION=gpu
SC_CURATION_MRVI_TIME=01:00:00
SC_CURATION_MRVI_CPUS=4
SC_CURATION_MRVI_MEM=32GB
SC_CURATION_MRVI_GPU_CONSTRAINT=       # 可选,如 GPU_MEM:24GB;空=不限(调度最快)
SC_CURATION_MRVI_MAX_EPOCHS=           # 空=scvi 默认轮数
SC_CURATION_LEIDEN_RESOLUTION=1.0
