# sc-curation-pipeline — 环境变量模板
#
# 用法:  cp .env.example .env   然后填上你的真实值。
# dg dev / dg check defs 启动时会自动加载项目根目录的 .env(无需手动 export)。
# .env 已被 .gitignore 忽略、不会提交;本模板 .env.example 可以提交。

# 必填:要监控的根目录(放在 $SCRATCH 下)。缺失会直接报错。
SC_CURATION_WATCH_DIR=/scratch/users/chensj16/sc-curation-watch

# 必填:标准化输出 .h5ad 的根目录(绝不写入源目录)。缺失会直接报错。
SC_CURATION_OUTPUT_DIR=/scratch/users/chensj16/sc-curation-output

# 以下均为可选;留空/删除用默认值,写成非法值也会安全退回默认值。

# 上传完成标记文件名(默认 .done)
SC_CURATION_DONE_MARKER=.done

# 文件夹内匹配 h5ad 的模式(默认 *.h5ad)
SC_CURATION_H5AD_GLOB=*.h5ad

# sensor 最小扫描间隔,秒(默认 30)
SC_CURATION_SCAN_INTERVAL_SEC=30

# 细胞数下限,低于则拒收(默认 100)
SC_CURATION_MIN_CELLS=100

# 检测到的基因总数下限(在 ≥1 细胞中 counts>0 的基因数);低于则拒收(默认 5000)
SC_CURATION_MIN_GENES=5000

# 细胞级过滤(cell_filtered 步骤):每个细胞检出基因数 < 此值的细胞被剔除(默认 400)
SC_CURATION_MIN_GENES_PER_CELL=400

# 元数据列识别(stanmetacols):1=LLM 优先+启发式回退(需 ANTHROPIC_API_KEY+外网),
# 0=离线启发式(确定性、零外部调用)。默认 1。
# ⚠️ Sherlock 计算节点跑批建议设 0:出网被代理黑洞时 LLM 读超时可能拖数十分钟才回退。
SC_CURATION_METACOLS_USE_LLM=1
